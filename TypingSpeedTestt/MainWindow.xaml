<Window x:Class="TypingSpeedTestWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Typing Speed Test" Height="700" Width="1250"
        Background="#121212" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid Margin="20">

        <!-- Title -->
        <TextBlock Text="Typing Speed Test"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="Cyan"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20" />

        <!-- Sentence Display -->
        <Border CornerRadius="12"
                Background="#1F1F1F"
                BorderBrush="#00FFFF"
                BorderThickness="2"
                Height="120"
                VerticalAlignment="Top"
                Margin="0,60,0,0"
                Padding="10">
            <TextBlock Name="SentenceTextBlock"
                       FontSize="22"
                       Foreground="Cyan"
                       TextWrapping="Wrap"
                       Text="Click Start to begin!"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Typing Input -->
        <TextBox Name="TypingTextBox"
                 FontSize="20"
                 Height="50"
                 Margin="0,200,0,0"
                 VerticalAlignment="Top"
                 Background="#1A1A1A"
                 Foreground="Cyan"
                 BorderBrush="#FF00FF"
                 BorderThickness="2"
                 Padding="5"
                 HorizontalContentAlignment="Left" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,270,0,0">
            <Button Name="StartButton"
                    Content="Start"
                    Width="140"
                    Height="50"
                    Background="Purple"
                    Foreground="Cyan"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="StartButton_Click"
                    Cursor="Hand"/>
            <Button Name="NextButton"
                    Content="Next"
                    Width="140"
                    Height="50"
                    Margin="20,0,0,0"
                    Background="#FF00FF"
                    Foreground="Cyan"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="NextButton_Click"
                    IsEnabled="False"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Sentence Count Selection -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,340,0,0">
            <TextBlock Text="Number of sentences:"
                       Foreground="Cyan"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <ComboBox Name="SentenceCountComboBox"
                      Width="100"
                      SelectedIndex="0"
                      Background="#1A1A1A"
                      Foreground="Cyan"
                      BorderBrush="Cyan"
                      BorderThickness="2">
                <ComboBoxItem>5</ComboBoxItem>
                <ComboBoxItem>10</ComboBoxItem>
                <ComboBoxItem>15</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- Results -->
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,400,0,0">
            <TextBlock Name="WPMLabel" Text="WPM: 0" FontSize="18" Foreground="Cyan" Margin="0,5"/>
            <TextBlock Name="AccuracyLabel" Text="Accuracy: 0%" FontSize="18" Foreground="Cyan" Margin="0,5"/>
            <TextBlock Name="BestLabel" Text="Best WPM: 0" FontSize="18" Foreground="Cyan" Margin="0,5"/>
        </StackPanel>

    </Grid>
</Window>
